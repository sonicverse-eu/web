10:T4d5,(function(){
  var STORAGE_KEY = 'sv-theme';
  var LIGHT_THEME = 'light';
  var DARK_THEME = 'dark';
  var mq = window.matchMedia('(prefers-color-scheme: dark)');
  var resolve = function(stored) {
    return stored === LIGHT_THEME || stored === DARK_THEME ? stored : (mq.matches ? DARK_THEME : LIGHT_THEME);
  };
  var sync = function() {
    try {
      var theme = resolve(localStorage.getItem(STORAGE_KEY));
      document.documentElement.setAttribute('data-theme', theme);
      return theme;
    } catch(e) {
      document.documentElement.setAttribute('data-theme', LIGHT_THEME);
      return LIGHT_THEME;
    }
  };
  window.__sonicverseSyncTheme = sync;
  window.__sonicverseApplyTheme = function(theme) {
    document.documentElement.setAttribute('data-theme', theme);
    try { localStorage.setItem(STORAGE_KEY, theme); } catch(e) {}
    return theme;
  };
  if (!window.__sonicverseThemeLifecycleBound) {
    window.addEventListener('storage', function(e) {
      if (!e.key || e.key === STORAGE_KEY) sync();
    });
    mq.addEventListener('change', function() {
      try { if (!localStorage.getItem(STORAGE_KEY)) sync(); } catch(e) { sync(); }
    });
    window.__sonicverseThemeLifecycleBound = true;
  }
  sync();
})();2:["$","html",null,{"lang":"en","children":[["$","head",null,{"children":[["$","meta",null,{"name":"theme-color","content":"#fafaff","media":"(prefers-color-scheme: light)"}],["$","meta",null,{"name":"theme-color","content":"#07060f","media":"(prefers-color-scheme: dark)"}],["$","script",null,{"dangerouslySetInnerHTML":{"__html":"$10"}}],["$","link",null,{"rel":"icon","type":"image/svg+xml","href":"/favicon.svg"}],["$","link",null,{"rel":"icon","href":"/favicon.ico"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}]]}],["$","body",null,{"children":[["$","a",null,{"className":"skip-link","href":"#main-content","children":"Skip to main content"}],["$","div",null,{"className":"background-atmosphere","aria-hidden":"true"}],["$","div",null,{"className":"dot-grid-overlay","aria-hidden":"true"}],["$","$L11",null,{"projects":[{"id":"audio-streaming-stack","body":"\nAudio Streaming Stack is a production-focused toolkit for stations and publishers that want full control over their broadcast infrastructure without rebuilding the basics from scratch.\n\n## What it includes\n\n- Icecast2 streaming and relay support\n- HLS output for modern web and mobile playback\n- Automatic failover and fallback behavior\n- Silence detection and operational alerting\n- A Docker Compose setup that is easy to run and adapt\n\n## Why it exists\n\nWe built this project to make dependable radio and live audio workflows easier to self-host. Instead of stitching together fragile pieces by hand, teams can start from a stack that already reflects real operational needs.\n\n## Good fit for\n\n- Independent broadcasters\n- Community radio stations\n- Experimental audio platforms\n- Teams that need a transparent base they can extend\n","data":{"title":"Audio Streaming Stack","summary":"Self-hosted Docker Compose stack for live radio with Icecast2, HLS adaptive bitrate, automatic fallback, silence detection, and real-time alerts.","repoUrl":"https://github.com/sonicverse-eu/audiostreaming-stack","status":"active","order":1}},{"id":"media-metadata-api","body":"\nMedia Metadata API provides a single, consistent interface for working with audio metadata across all the formats your workflows encounter.\n\n## What it includes\n\n- Read and write ID3v2, Vorbis Comment, MP4/iTunes, and FLAC metadata\n- Normalise fields across formats into a unified schema\n- Podcast-specific fields: GUID, episode type, season, chapter marks\n- Batch processing endpoint for large media libraries\n- Lightweight self-hostable Node service\n\n## Why it exists\n\nEvery audio format stores metadata differently. Teams end up writing one-off parsers for each format they touch. This project removes that friction with a single, well-documented API that handles the edge cases so you don't have to.\n\n## Good fit for\n\n- Podcast publishing platforms\n- Radio archive systems\n- Media asset management teams\n- Developers building audio pipelines\n","data":{"title":"Media Metadata API","summary":"Unified REST API for reading, writing, and normalizing metadata across audio and podcast formats — ID3, Vorbis, MP4, RSS.","repoUrl":"https://github.com/sonicverse-eu","status":"planned","order":2}},{"id":"broadcast-scheduler","body":"\nBroadcast Scheduler gives independent stations a programmable, self-hosted playout scheduler that connects to the tools they already run.\n\n## What it includes\n\n- Visual schedule builder with drag-and-drop hour blocks\n- Integration adapters for Liquidsoap and AzuraCast\n- Show rotation, live override, and fallback playlist support\n- REST API for automation and third-party integrations\n- Exportable schedule data in standard formats\n\n## Why it exists\n\nMost scheduler solutions are either locked to proprietary hardware or require expensive licensing. This project gives community stations a modern, open alternative that they can run on any server.\n\n## Good fit for\n\n- Community radio stations\n- Podcast networks running live shows\n- College and non-commercial broadcasters\n- Teams wanting to replace legacy playout software\n","data":{"title":"Broadcast Scheduler","summary":"Open scheduling engine for live and automated radio playout — integrates with Liquidsoap, AzuraCast, and custom station software.","repoUrl":"https://github.com/sonicverse-eu","status":"alpha","order":3}}]}],"$L12","$L13","$L14"]}]]}]
