11:["$","section",null,{"className":"container section-gap","children":["$","section",null,{"className":"cta-band","data-reveal":true,"children":[["$","div",null,{"className":"cta-glow","aria-hidden":"true"}],["$","p",null,{"className":"eyebrow","children":"Get involved"}],["$","h2",null,{"className":"gradient-text","children":"Build the open future of independent media with us."}],["$","p",null,{"children":"Whether you're a developer, broadcaster, or publisher — there's a place for you in the Sonicverse community."}],["$","div",null,{"className":"button-row","children":[["$","a",null,{"className":"button button-primary","href":"/community","children":"Become a contributor"}],["$","a",null,{"className":"button button-ghost","href":"/projects","children":"Explore projects"}]]}]]}]}]
