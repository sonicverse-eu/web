---
export interface CTALink {
	label: string;
	href: string;
}

export interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	primary: CTALink;
	secondary?: CTALink;
}

const { eyebrow, title, subtitle, primary, secondary } = Astro.props;
---

<section class="cta-band" data-reveal>
	<div class="cta-glow" aria-hidden="true"></div>
	{eyebrow && <p class="eyebrow">{eyebrow}</p>}
	<h2 class="gradient-text">{title}</h2>
	{subtitle && <p>{subtitle}</p>}
	<div class="button-row">
		<a class="button button-primary" href={primary.href}>{primary.label}</a>
		{secondary && <a class="button button-ghost" href={secondary.href}>{secondary.label}</a>}
	</div>
</section>

<style>
	.cta-glow {
		position: absolute;
		width: 40%;
		height: 60%;
		border-radius: 50%;
		background: radial-gradient(
			circle,
			color-mix(in srgb, var(--brand-500) 20%, transparent) 0%,
			transparent 70%
		);
		filter: blur(50px);
		top: 20%;
		left: 30%;
		pointer-events: none;
		z-index: 0;
		animation: sv-glow-drift 10s ease-in-out infinite alternate;
	}
</style>
