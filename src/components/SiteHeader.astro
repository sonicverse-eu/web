---
import brandIcon from '../assets/brand/2.svg';
import ThemeToggle from './ThemeToggle.astro';
import { getCollection } from 'astro:content';
import ProjectIcon from './ProjectIcon.astro';

export interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);

const getProjectSlug = (project: (typeof projects)[number]) =>
  project.id.replace(/\.(md|mdoc)$/, '');


const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/community', label: 'Community' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' }
];
const docsHref = 'https://docs.sonicverse.eu';

const normalizePath = (path: string) => (path !== '/' ? path.replace(/\/+$/, '') : '/');

const isActive = (href: string, path: string = currentPath) => {
  const normalizedHref = normalizePath(href);
  const normalizedPath = normalizePath(path);

  return normalizedHref === '/'
    ? normalizedPath === '/'
    : normalizedPath === normalizedHref || normalizedPath.startsWith(`${normalizedHref}/`);
};
---

<header class="top-nav-wrap" transition:persist>
  <div class="top-nav container">
    <a class="brand" href="/" aria-label="Sonicverse home">
      <img class="brand-mark" src={brandIcon.src} alt="Sonicverse logo" />
      <span class="brand-copy">
        <strong>Sonicverse</strong>
      </span>
    </a>
    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-nav-shell"
      aria-label="Open navigation menu"
      data-nav-toggle
    >
      <span class="nav-toggle-box" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
      <span class="nav-toggle-label">Menu</span>
    </button>
    <nav class="desktop-nav" aria-label="Primary">
      <span class="nav-indicator" aria-hidden="true"></span>
      <ul class="nav-list nav-list--desktop">
        <li class="nav-has-dropdown">
          <a
            class:list={['nav-link--desktop', 'has-dropdown', { active: isActive('/projects') }]}
            href="/projects"
            data-nav-link
            data-desktop-nav-link
            aria-current={isActive('/projects') ? 'page' : undefined}
          >
            Products
          </a>
          {projects.length > 0 && (
            <div class="nav-dropdown" role="menu">
              <div class="nav-dropdown-header">
                <span class="nav-dropdown-header-label">Our open source projects</span>
              </div>
              <div class="nav-dropdown-body">
                {projects.map((project) => (
                  <a
                    class="nav-dropdown-item"
                    href={`/projects/${getProjectSlug(project)}/`}
                    role="menuitem"
                  >
                    <span class="nav-dropdown-icon" aria-hidden="true">
                      <ProjectIcon slug={getProjectSlug(project)} size={16} />
                    </span>
                    <span class="nav-dropdown-text">
                      <span class="nav-dropdown-title">{project.data.title}</span>
                      <span class="nav-dropdown-desc">{project.data.summary.slice(0, 60)}{project.data.summary.length > 60 ? '…' : ''}</span>
                    </span>
                    <span class={`badge badge-${project.data.status}`}>{project.data.status}</span>
                  </a>
                ))}
              </div>
              <div class="nav-dropdown-footer">
                <span class="nav-dropdown-footer-label">{projects.length} open source project{projects.length !== 1 ? 's' : ''}</span>
                <a href="/projects">View all →</a>
              </div>
            </div>
          )}
        </li>
        {
          navLinks.map((link) => (
            <li>
              <a
                class:list={['nav-link--desktop', { active: isActive(link.href) }]}
                href={link.href}
                data-nav-link
                data-desktop-nav-link
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a
        class="button button-primary docs-nav-button docs-nav-button--desktop"
        href={docsHref}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Open Sonicverse documentation in a new tab"
      >
        Docs
      </a>
      <ThemeToggle />
    </nav>
  </div>
</header>
<div
  id="mobile-nav-shell"
  class="mobile-nav-shell"
  data-mobile-shell
  aria-hidden="true"
  hidden
  transition:persist="mobile-nav"
>
  <button
    class="mobile-nav-backdrop"
    type="button"
    aria-label="Close navigation menu"
    data-mobile-nav-close
    tabindex="-1"
  ></button>
  <div
    class="mobile-nav-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-nav-title"
    tabindex="-1"
    data-mobile-nav-panel
  >
    <div class="mobile-nav-head">
      <p id="mobile-nav-title">Menu</p>
      <button
        class="mobile-nav-close"
        type="button"
        aria-label="Close navigation menu"
        data-mobile-nav-close
      >
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
    <nav aria-label="Mobile">
      {projects.length > 0 && (
        <div class="mobile-nav-section">
          <p class="mobile-nav-section-label">Products</p>
          <ul class="mobile-nav-list mobile-nav-list--products">
            {projects.map((project, i) => (
              <li style={`transition-delay:${60 + i * 40}ms`}>
                <a
                  class={`mobile-nav-product-item${isActive(`/projects/${getProjectSlug(project)}/`) ? ' active' : ''}`}
                  href={`/projects/${getProjectSlug(project)}/`}
                  data-nav-link
                  data-mobile-nav-link
                  aria-current={isActive(`/projects/${getProjectSlug(project)}/`) ? 'page' : undefined}
                >
                  <span class="mobile-nav-product-icon">
                    <ProjectIcon slug={getProjectSlug(project)} size={15} />
                  </span>
                  <span class="mobile-nav-product-info">
                    <span class="mobile-nav-product-name">{project.data.title}</span>
                    <span class={`badge badge-${project.data.status}`}>{project.data.status}</span>
                  </span>
                </a>
              </li>
            ))}
            <li style={`transition-delay:${60 + projects.length * 40}ms`}>
              <a
                class={isActive('/projects') ? 'active' : ''}
                href="/projects"
                data-nav-link
                data-mobile-nav-link
                style="font-size:0.82rem;color:var(--text-muted);"
              >
                View all products →
              </a>
            </li>
          </ul>
        </div>
      )}
      <div class="mobile-nav-section">
        <p class="mobile-nav-section-label">Navigate</p>
        <ul class="mobile-nav-list">
          {
            navLinks.map((link) => (
              <li>
                <a
                  class={isActive(link.href) ? 'active' : ''}
                  href={link.href}
                  data-nav-link
                  data-mobile-nav-link
                  aria-current={isActive(link.href) ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <a
        class="button button-primary docs-nav-button docs-nav-button--mobile"
        href={docsHref}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Open Sonicverse documentation in a new tab"
        data-mobile-nav-docs
      >
        Docs
      </a>
    </nav>
  </div>
</div>

<script>
  const navWindow = window as Window & {
    __sonicverseNavBound?: boolean;
    __sonicverseLastNavPath?: string;
    __sonicverseMobileNavHideTimer?: number;
    __sonicverseMobileNavRestoreFocus?: HTMLElement | null;
    __sonicverseScrollCleanup?: (() => void) | null;
  };

  const navOrder = ['/', '/projects', '/about', '/community', '/blog', '/contact', '/contact'];
  const mobileNavMediaQuery = window.matchMedia('(max-width: 700px)');
  const mobileNavTransitionMs = 320;
  const focusableSelector =
    'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

  /* ── Scroll-direction header hide/show ── */
  const SCROLL_THRESHOLD = 64;   // px before hide/show kicks in
  const SCROLL_DELTA     = 8;    // minimum px change to trigger

  const reduceMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

  let lastScrollY = window.scrollY;
  let ticking = false;

  const getHeaderElement = () => document.querySelector<HTMLElement>('.top-nav-wrap');

  const updateHeaderVisibility = () => {
    const header = getHeaderElement();
    if (!header) return;

    const currentY = window.scrollY;
    const delta = currentY - lastScrollY;

    // Apply condensed styling once scrolled past threshold
    header.dataset.scrolled = currentY > SCROLL_THRESHOLD ? 'true' : 'false';

    // Never hide at the very top
    if (currentY <= SCROLL_THRESHOLD) {
      header.dataset.navHidden = 'false';
      lastScrollY = currentY;
      ticking = false;
      return;
    }

    // Ignore tiny scroll movements (jitter guard)
    if (Math.abs(delta) < SCROLL_DELTA) {
      ticking = false;
      return;
    }

    // Don't hide when mobile nav is open
    if (isMobileNavOpen()) {
      lastScrollY = currentY;
      ticking = false;
      return;
    }

    // Skip hide/show for reduced-motion users
    if (reduceMotionQuery.matches) {
      lastScrollY = currentY;
      ticking = false;
      return;
    }

    header.dataset.navHidden = delta > 0 ? 'true' : 'false';
    lastScrollY = currentY;
    ticking = false;
  };

  const onScroll = () => {
    if (!ticking) {
      requestAnimationFrame(updateHeaderVisibility);
      ticking = true;
    }
  };

  const initScrollBehavior = () => {
    // Clean up previous listener if any (for page transitions)
    navWindow.__sonicverseScrollCleanup?.();

    lastScrollY = window.scrollY;
    const header = getHeaderElement();
    if (header) {
      header.dataset.navHidden = 'false';
      header.dataset.scrolled = window.scrollY > SCROLL_THRESHOLD ? 'true' : 'false';
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    navWindow.__sonicverseScrollCleanup = () => {
      window.removeEventListener('scroll', onScroll);
    };
  };

  const normalizePath = (path: string) => (path !== '/' ? path.replace(/\/+$/, '') : '/');

  const isActivePath = (href: string, path: string) => {
    const normalizedHref = normalizePath(href);
    const normalizedPath = normalizePath(path);

    return normalizedHref === '/'
      ? normalizedPath === '/'
      : normalizedPath === normalizedHref || normalizedPath.startsWith(`${normalizedHref}/`);
  };

  let indicatorReady = false;

  const updateNavIndicator = (instant = false) => {
    const nav = document.querySelector<HTMLElement>('.desktop-nav');
    const navList = document.querySelector<HTMLElement>('.nav-list--desktop');
    const indicator = nav?.querySelector<HTMLElement>('.nav-indicator');
    const activeLink = navList?.querySelector<HTMLAnchorElement>('a[data-desktop-nav-link].active');

    if (!navList || !indicator) return;
    if (window.getComputedStyle(navList).display === 'none') {
      indicator.style.opacity = '0';
      return;
    }

    if (!activeLink) {
      indicator.style.opacity = '0';
      return;
    }

    const navRect = navList.getBoundingClientRect();
    const linkRect = activeLink.getBoundingClientRect();
    const left = linkRect.left - navRect.left;
    const width = linkRect.width;

    if (!indicatorReady || instant) {
      // Snap to position on first render (no animation)
      indicator.style.transition = 'none';
      indicator.style.left = `${left}px`;
      indicator.style.width = `${width}px`;
      // Force reflow then re-enable transitions
      indicator.getBoundingClientRect();
      indicator.style.transition = '';
      indicator.style.opacity = '1';
      indicatorReady = true;
    } else {
      indicator.style.left = `${left}px`;
      indicator.style.width = `${width}px`;
      indicator.style.opacity = '1';
    }
  };

  const getMobileNavElements = () => {
    const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
    const shell = document.querySelector<HTMLElement>('[data-mobile-shell]');
    const panel = shell?.querySelector<HTMLElement>('[data-mobile-nav-panel]') ?? null;
    const firstFocusable =
      panel?.querySelector<HTMLElement>('[data-mobile-nav-close], a[data-mobile-nav-link]') ?? null;

    return { toggle, shell, panel, firstFocusable };
  };

  const setBackgroundLocked = (locked: boolean) => {
    document.documentElement.toggleAttribute('data-mobile-nav-open', locked);
    document.body.style.overflow = locked ? 'hidden' : '';

    [document.querySelector('.top-nav-wrap'), document.querySelector('main'), document.querySelector('.site-footer')].forEach((element) => {
      if (!element) return;

      if (locked) {
        element.setAttribute('inert', '');
      } else {
        element.removeAttribute('inert');
      }
    });
  };

  const isMobileNavOpen = () => {
    const { shell } = getMobileNavElements();
    return shell?.dataset.open === 'true';
  };

  const closeMobileNav = ({
    immediate = false,
    restoreFocus = true
  }: {
    immediate?: boolean;
    restoreFocus?: boolean;
  } = {}) => {
    const { toggle, shell } = getMobileNavElements();
    if (!toggle || !shell) return;

    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open navigation menu');
    shell.setAttribute('aria-hidden', 'true');
    setBackgroundLocked(false);

    const finishClose = () => {
      shell.hidden = true;
      shell.dataset.open = 'false';
      navWindow.__sonicverseMobileNavHideTimer = undefined;
    };

    window.clearTimeout(navWindow.__sonicverseMobileNavHideTimer);

    if (immediate) {
      finishClose();
    } else {
      shell.dataset.open = 'false';
      navWindow.__sonicverseMobileNavHideTimer = window.setTimeout(finishClose, mobileNavTransitionMs);
    }

    if (restoreFocus && navWindow.__sonicverseMobileNavRestoreFocus) {
      navWindow.__sonicverseMobileNavRestoreFocus.focus();
    }
  };

  const openMobileNav = () => {
    const { toggle, shell, firstFocusable } = getMobileNavElements();
    if (!toggle || !shell || !mobileNavMediaQuery.matches) return;

    navWindow.__sonicverseMobileNavRestoreFocus =
      document.activeElement instanceof HTMLElement ? document.activeElement : toggle;

    // Force header visible when opening the mobile nav
    const header = getHeaderElement();
    if (header) header.dataset.navHidden = 'false';

    window.clearTimeout(navWindow.__sonicverseMobileNavHideTimer);
    shell.hidden = false;
    shell.setAttribute('aria-hidden', 'false');
    shell.dataset.open = 'false';
    setBackgroundLocked(true);
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close navigation menu');

    requestAnimationFrame(() => {
      shell.dataset.open = 'true';
      firstFocusable?.focus();
    });
  };

  const trapMobileNavFocus = (event: KeyboardEvent) => {
    if (!isMobileNavOpen() || event.key !== 'Tab') return;

    const { panel } = getMobileNavElements();
    if (!panel) return;

    const focusableElements = Array.from(panel.querySelectorAll<HTMLElement>(focusableSelector)).filter(
      (element) => !element.hasAttribute('disabled')
    );

    if (!focusableElements.length) {
      event.preventDefault();
      panel.focus();
      return;
    }

    const first = focusableElements[0];
    const last = focusableElements[focusableElements.length - 1];
    const activeElement =
      document.activeElement instanceof HTMLElement ? document.activeElement : null;

    if (!activeElement || !panel.contains(activeElement)) {
      event.preventDefault();
      first.focus();
      return;
    }

    if (event.shiftKey && activeElement === first) {
      event.preventDefault();
      last.focus();
      return;
    }

    if (!event.shiftKey && activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  };

  const syncActiveNavItem = () => {
    const path = window.location.pathname;
    const links = document.querySelectorAll('a[data-nav-link]');

    links.forEach((link) => {
      const href = link.getAttribute('href') || '/';
      const active = isActivePath(href, path);

      link.classList.toggle('active', active);
      if (active) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });

    updateNavIndicator();
  };

  const getNavIndex = (path: string) =>
    navOrder.findIndex((href) => isActivePath(href, path));

  const setDirectionalTransition = (fromPath: string, toPath: string) => {
    const fromIndex = getNavIndex(fromPath);
    const toIndex = getNavIndex(toPath);

    if (fromIndex === -1 || toIndex === -1 || fromIndex === toIndex) {
      document.documentElement.removeAttribute('data-nav-direction');
      return;
    }

    document.documentElement.setAttribute('data-nav-direction', toIndex > fromIndex ? 'left' : 'right');
  };

  const trackNavDirection = (event: Event) => {
    const clickEvent = event as MouseEvent;
    if (clickEvent.defaultPrevented || clickEvent.button !== 0 || clickEvent.metaKey || clickEvent.ctrlKey || clickEvent.shiftKey || clickEvent.altKey) {
      return;
    }

    const target = clickEvent.target as Element | null;
    const link = target?.closest('a[data-nav-link]') as HTMLAnchorElement | null;
    if (!link || !link.href) {
      return;
    }

    const nextUrl = new URL(link.href, window.location.origin);
    if (nextUrl.origin !== window.location.origin) {
      return;
    }

    if (normalizePath(nextUrl.pathname) === normalizePath(window.location.pathname)) {
      clickEvent.preventDefault();
      clickEvent.stopImmediatePropagation();
      document.documentElement.removeAttribute('data-nav-direction');
      if (link.hasAttribute('data-mobile-nav-link')) {
        closeMobileNav();
      }
      return;
    }

    setDirectionalTransition(window.location.pathname, nextUrl.pathname);
    if (link.hasAttribute('data-mobile-nav-link')) {
      closeMobileNav({ restoreFocus: false });
    }

    // Slide indicator to the clicked link immediately (before page transition)
    const navList = link.closest<HTMLElement>('.nav-list--desktop');
    const nav = link.closest<HTMLElement>('.desktop-nav');
    const indicator = nav?.querySelector<HTMLElement>('.nav-indicator');
    if (navList && indicator) {
      const navRect = navList.getBoundingClientRect();
      const linkRect = link.getBoundingClientRect();
      indicator.style.left = `${linkRect.left - navRect.left}px`;
      indicator.style.width = `${linkRect.width}px`;
      indicator.style.opacity = '1';
    }
  };

  const onDocumentClick = (event: Event) => {
    const target = event.target as Element | null;
    if (!target) return;

    if (target.closest('[data-nav-toggle]')) {
      event.preventDefault();
      if (isMobileNavOpen()) {
        closeMobileNav();
      } else {
        openMobileNav();
      }
      return;
    }

    if (target.closest('[data-mobile-nav-close]')) {
      event.preventDefault();
      closeMobileNav();
      return;
    }

    if (target.closest('[data-mobile-nav-docs]')) {
      closeMobileNav({ restoreFocus: false });
    }
  };

  const onDocumentKeydown = (event: KeyboardEvent) => {
    if (event.key === 'Escape' && isMobileNavOpen()) {
      event.preventDefault();
      closeMobileNav();
      return;
    }

    trapMobileNavFocus(event);
  };

  if (!navWindow.__sonicverseNavBound) {
    document.addEventListener('click', trackNavDirection, { capture: true });
    document.addEventListener('click', onDocumentClick);
    document.addEventListener('keydown', onDocumentKeydown);
    document.addEventListener('astro:page-load', syncActiveNavItem);
    document.addEventListener('astro:page-load', () => {
      const previousPath = navWindow.__sonicverseLastNavPath;
      if (previousPath) {
        setDirectionalTransition(previousPath, window.location.pathname);
      }
      navWindow.__sonicverseLastNavPath = window.location.pathname;
      closeMobileNav({ immediate: true, restoreFocus: false });
      initScrollBehavior();
    });
    window.addEventListener('resize', () => updateNavIndicator(true));
    mobileNavMediaQuery.addEventListener('change', (event) => {
      if (!event.matches) {
        closeMobileNav({ immediate: true, restoreFocus: false });
      }
    });

    navWindow.__sonicverseLastNavPath = window.location.pathname;
    navWindow.__sonicverseNavBound = true;
  }

  closeMobileNav({ immediate: true, restoreFocus: false });
  syncActiveNavItem();
  updateNavIndicator(true);
  initScrollBehavior();
</script>
