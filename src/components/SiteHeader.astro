---
import { getCollection } from 'astro:content';
import brandIcon from '../assets/brand/2.svg';

export interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const products = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const navLinks = [
	{ href: '/pricing', label: 'Pricing' },
	{ href: '/community', label: 'Open Source' },
	{ href: '/about', label: 'About' },
	{ href: '/blog', label: 'Insights' },
	{ href: '/contact', label: 'Contact' }
];

const normalizePath = (path: string) => (path !== '/' ? path.replace(/\/+$/, '') : '/');

const isActive = (href: string, path: string = currentPath) => {
	const normalizedHref = normalizePath(href);
	const normalizedPath = normalizePath(path);

	return normalizedHref === '/'
		? normalizedPath === '/'
		: normalizedPath === normalizedHref || normalizedPath.startsWith(`${normalizedHref}/`);
};

const isProductsActive = isActive('/products');
---

<header class="site-header" transition:persist>
	<div class="container site-header__inner">
		<a class="brand" href="/" aria-label="Sonicverse home">
			<img class="brand-mark" src={brandIcon.src} alt="Sonicverse logo" loading="eager" decoding="async" />
			<span class="brand-copy">
				<strong>Sonicverse</strong>
				<span>Open audio platform</span>
			</span>
		</a>

		<button
			class="nav-toggle"
			type="button"
			aria-expanded="false"
			aria-controls="mobile-nav"
			data-nav-toggle
		>
			Menu
		</button>

		<nav class="site-nav" aria-label="Primary">
			<div class:list={['products-menu', isProductsActive && 'is-active']}>
				<button
					class:list={['site-nav__link', 'products-menu__trigger', isProductsActive && 'is-active']}
					type="button"
					aria-expanded={isProductsActive ? 'true' : 'false'}
					aria-controls="products-popover"
					data-products-trigger
				>
					Products
				</button>
				<div class="products-popover-shell" data-products-shell hidden>
					<button
						class="products-popover-backdrop"
						type="button"
						aria-label="Close products menu"
						data-products-close
						tabindex="-1"
					></button>
					<div class="products-popover" id="products-popover" data-products-popover>
					<p class="products-popover__eyebrow">Find your fit</p>
						<div class="products-popover__intro">
							<div>
								<h2>Three products, one open platform.</h2>
								<p>Pick the product that matches your immediate bottleneck, then expand into the rest of the stack when you are ready.</p>
							</div>
							<a class="button button-secondary" href="/products">Compare all products</a>
						</div>
						<div class="products-popover__grid">
							{
								products.map((product) => {
									const slug = product.id.replace(/\.(md|mdoc)$/, '');
									return (
										<a class="products-popover__card" href={`/products/${slug}/`}>
											<span class={`status-pill status-pill--${product.data.status}`}>{product.data.status}</span>
											<strong>{product.data.title}</strong>
											<span>{product.data.tagline}</span>
											<em>{product.data.category}</em>
										</a>
									);
								})
							}
						</div>
						<div class="products-popover__footer">
							<span>Need help choosing?</span>
							<a href="/contact">Request a guided walkthrough</a>
						</div>
					</div>
				</div>
			</div>

			{
				navLinks.map((link) => (
					<a
						class:list={['site-nav__link', isActive(link.href) && 'is-active']}
						href={link.href}
						aria-current={isActive(link.href) ? 'page' : undefined}
					>
						{link.label}
					</a>
				))
			}
		</nav>

		<div class="site-header__actions">
			<a class="button button-secondary" href="/products">Compare products</a>
			<a class="button button-primary" href="/contact">Request a demo</a>
		</div>
	</div>
</header>

<div class="mobile-nav-shell" id="mobile-nav" data-mobile-shell hidden transition:persist="mobile-nav">
	<button class="mobile-nav-backdrop" type="button" aria-label="Close navigation" data-mobile-nav-close></button>
	<div class="mobile-nav-panel" role="dialog" aria-modal="true" aria-labelledby="mobile-nav-title">
		<div class="mobile-nav-panel__head">
			<p id="mobile-nav-title">Navigate Sonicverse</p>
			<button type="button" class="mobile-nav-close" aria-label="Close navigation" data-mobile-nav-close>
				&times;
			</button>
		</div>

		<div class="mobile-nav-panel__body">
			<div class="mobile-nav-group">
				<p class="mobile-nav-label">Products</p>
				{
					products.map((product) => {
						const slug = product.id.replace(/\.(md|mdoc)$/, '');
						return (
							<a class="mobile-product-link" href={`/products/${slug}/`}>
								<strong>{product.data.title}</strong>
								<span>{product.data.tagline}</span>
							</a>
						);
					})
				}
				<a class="mobile-nav-link mobile-nav-link--summary" href="/products">Compare all products</a>
			</div>

			<div class="mobile-nav-group">
				<p class="mobile-nav-label">Company</p>
				{
					navLinks.map((link) => (
						<a
							class:list={['mobile-nav-link', isActive(link.href) && 'is-active']}
							href={link.href}
							aria-current={isActive(link.href) ? 'page' : undefined}
						>
							{link.label}
						</a>
					))
				}
			</div>

			<div class="mobile-nav-group mobile-nav-group--cta">
				<a class="button button-secondary" href="/pricing">View pricing</a>
				<a class="button button-primary" href="/contact">Request a demo</a>
			</div>
		</div>
	</div>
</div>

<script>
	const navWindow = window as Window & {
		__sonicverseNavBound?: boolean;
		__sonicverseNavCleanup?: (() => void) | null;
	};

	const bindNav = () => {
		navWindow.__sonicverseNavCleanup?.();

		const toggle = document.querySelector<HTMLElement>('[data-nav-toggle]');
		const shell = document.querySelector<HTMLElement>('[data-mobile-shell]');
		const closeButtons = Array.from(document.querySelectorAll<HTMLElement>('[data-mobile-nav-close]'));
		const productsTrigger = document.querySelector<HTMLButtonElement>('[data-products-trigger]');
		const productsShell = document.querySelector<HTMLElement>('[data-products-shell]');
		const productsPopover = document.querySelector<HTMLElement>('[data-products-popover]');
		const productsCloseButtons = Array.from(document.querySelectorAll<HTMLElement>('[data-products-close]'));

		if (!toggle || !shell) {
			return;
		}

		const closeMenu = () => {
			shell.hidden = true;
			document.body.removeAttribute('data-mobile-nav-open');
			toggle.setAttribute('aria-expanded', 'false');
		};

		const openMenu = () => {
			shell.hidden = false;
			document.body.setAttribute('data-mobile-nav-open', 'true');
			toggle.setAttribute('aria-expanded', 'true');
		};

		const onToggleClick = () => {
			if (shell.hidden) {
				openMenu();
			} else {
				closeMenu();
			}
		};

		const closeProductsMenu = () => {
			if (!productsShell || !productsTrigger) return;
			productsShell.hidden = true;
			productsTrigger.setAttribute('aria-expanded', 'false');
			document.body.removeAttribute('data-products-menu-open');
		};

		const openProductsMenu = () => {
			if (!productsShell || !productsTrigger) return;
			productsShell.hidden = false;
			productsTrigger.setAttribute('aria-expanded', 'true');
			document.body.setAttribute('data-products-menu-open', 'true');
		};

		const onProductsToggle = () => {
			if (!productsShell || !productsTrigger) return;
			if (productsShell.hidden) {
				openProductsMenu();
			} else {
				closeProductsMenu();
			}
		};

		const onDocumentClick = (event: MouseEvent) => {
			if (!productsShell || !productsTrigger || productsShell.hidden) return;
			const target = event.target as Node | null;
			if (!target) return;
			if (productsPopover?.contains(target) || productsTrigger.contains(target)) return;
			closeProductsMenu();
		};

		const onProductsFocusOut = (event: FocusEvent) => {
			if (!productsShell || productsShell.hidden) return;
			const nextTarget = event.relatedTarget as Node | null;
			const wrapper = document.querySelector('.products-menu');
			if (nextTarget && wrapper?.contains(nextTarget)) return;
			closeProductsMenu();
		};

		const onKeyDown = (event: KeyboardEvent) => {
			if (event.key === 'Escape') {
				closeMenu();
				closeProductsMenu();
			}
		};

		toggle.addEventListener('click', onToggleClick);
		closeButtons.forEach((button) => button.addEventListener('click', closeMenu));
		productsTrigger?.addEventListener('click', onProductsToggle);
		productsCloseButtons.forEach((button) => button.addEventListener('click', closeProductsMenu));
		productsPopover?.addEventListener('focusout', onProductsFocusOut);
		document.addEventListener('click', onDocumentClick);
		document.addEventListener('keydown', onKeyDown);

		navWindow.__sonicverseNavCleanup = () => {
			toggle.removeEventListener('click', onToggleClick);
			closeButtons.forEach((button) => button.removeEventListener('click', closeMenu));
			productsTrigger?.removeEventListener('click', onProductsToggle);
			productsCloseButtons.forEach((button) => button.removeEventListener('click', closeProductsMenu));
			productsPopover?.removeEventListener('focusout', onProductsFocusOut);
			document.removeEventListener('click', onDocumentClick);
			document.removeEventListener('keydown', onKeyDown);
		};
	};

	if (!navWindow.__sonicverseNavBound) {
		document.addEventListener('astro:page-load', bindNav);
		navWindow.__sonicverseNavBound = true;
	}

	bindNav();
</script>
