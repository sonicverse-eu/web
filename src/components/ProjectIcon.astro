---
import RadioTower from 'lucide-astro/RadioTower';
import Tags from 'lucide-astro/Tags';
import CalendarClock from 'lucide-astro/CalendarClock';
import Zap from 'lucide-astro/Zap';

export interface Props {
  slug: string;
  size?: number;
  class?: string;
}

const { slug, size = 20, class: cls } = Astro.props;

const icons: Record<string, any> = {
  'audio-streaming-stack': RadioTower,
  'media-metadata-api': Tags,
  'broadcast-scheduler': CalendarClock,
};

const Icon = icons[slug] ?? Zap;
---

<Icon size={size} class={cls} />
