---
export interface Props {
  title?: string;
  eyebrow?: string;
  tone?: 'default' | 'accent' | 'warm';
}

const { title, eyebrow = 'Callout', tone = 'default' } = Astro.props;
const toneClass = `callout-${tone}`;
const sectionId = title ? `callout-${crypto.randomUUID()}` : undefined;
---

<section class={`callout-panel ${toneClass}`} aria-labelledby={sectionId} data-reveal>
  <div class="callout-shell">
    {(eyebrow || title) && (
      <header class="callout-header">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {title && <h2 id={sectionId}>{title}</h2>}
      </header>
    )}
    <div class="callout-body">
      <slot />
    </div>
  </div>
</section>

<style>
  .callout-panel {
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  .callout-shell {
    position: relative;
    padding: clamp(1.4rem, 3vw, 2rem);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-subtle);
    background: var(--surface);
    backdrop-filter: blur(10px);
    overflow: hidden;
  }

  .callout-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at 0% 0%, var(--brand-surface), transparent 55%);
    pointer-events: none;
    opacity: 0.6;
  }

  .callout-accent .callout-shell {
    border-color: var(--border-strong);
    background: var(--surface-strong);
  }
  .callout-accent .callout-shell::before {
    background: radial-gradient(circle at 100% 0%, var(--brand-surface-strong), transparent 55%);
    opacity: 1;
  }

  .callout-warm .callout-shell {
    border-color: color-mix(in srgb, #f59e0b 28%, transparent);
  }
  .callout-warm .callout-shell::before {
    background: radial-gradient(circle at 100% 0%, color-mix(in srgb, #f59e0b 18%, transparent), transparent 55%);
    opacity: 1;
  }

  .callout-header {
    position: relative;
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .callout-header h2 {
    margin: 0;
    font-size: var(--text-xl);
  }

  .callout-body {
    position: relative;
  }

  .callout-body :global(*:first-child) { margin-top: 0; }
  .callout-body :global(*:last-child) { margin-bottom: 0; }
  .callout-body :global(p),
  .callout-body :global(li) {
    color: var(--text-muted);
    line-height: 1.65;
  }
</style>
