---
export interface Props {
  title?: string;
  eyebrow?: string;
  tone?: 'default' | 'accent' | 'warm';
}

const { title, eyebrow = 'Callout', tone = 'default' } = Astro.props;
const toneClass = `callout-${tone}`;
const sectionId = title ? `callout-${crypto.randomUUID()}` : undefined;
---

<section class={`callout-panel ${toneClass}`} aria-labelledby={sectionId} data-reveal>
  <div class="callout-shell">
    {(eyebrow || title) && (
      <header class="callout-header">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {title && <h2 id={sectionId}>{title}</h2>}
      </header>
    )}
    <div class="callout-body">
      <slot />
    </div>
  </div>
</section>

<style>
  .callout-panel {
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  .callout-shell {
    padding: clamp(1.35rem, 3vw, 2rem);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.8);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.82)),
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.55), transparent 45%);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
  }

  .callout-default .callout-shell {
    border-color: color-mix(in srgb, var(--primary-500) 10%, rgba(255, 255, 255, 0.9));
  }

  .callout-accent .callout-shell {
    border-color: color-mix(in srgb, var(--primary-500) 22%, rgba(255, 255, 255, 0.88));
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--primary-50) 72%, white), rgba(255, 255, 255, 0.88)),
      radial-gradient(circle at top right, color-mix(in srgb, var(--primary-300) 22%, transparent), transparent 48%);
  }

  .callout-warm .callout-shell {
    border-color: color-mix(in srgb, #f59e0b 22%, rgba(255, 255, 255, 0.88));
    background:
      linear-gradient(145deg, color-mix(in srgb, #fef3c7 50%, white), rgba(255, 255, 255, 0.9)),
      radial-gradient(circle at top right, color-mix(in srgb, #f59e0b 18%, transparent), transparent 48%);
  }

  .callout-header {
    display: grid;
    gap: 0.45rem;
    margin-bottom: 0.9rem;
  }

  .callout-header h2 {
    margin: 0;
  }

  .callout-body :global(*:first-child) {
    margin-top: 0;
  }

  .callout-body :global(*:last-child) {
    margin-bottom: 0;
  }
</style>
