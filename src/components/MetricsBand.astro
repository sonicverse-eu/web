---
export interface Metric {
	value: string;
	label: string;
}

export interface Props {
	metrics: Metric[];
}

const { metrics } = Astro.props;
---

{metrics.length > 0 && (
	<div class="metrics-band" data-reveal>
		{metrics.map((metric) => (
			<div class="metric">
				<div class="metric-value">{metric.value}</div>
				<div class="metric-label">{metric.label}</div>
			</div>
		))}
	</div>
)}
