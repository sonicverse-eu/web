---
interface ActionLink {
	label: string;
	href: string;
}

export interface Props {
	eyebrow?: string;
	title: string;
	subtitle: string;
	primary?: ActionLink;
	secondary?: ActionLink;
	align?: 'left' | 'center';
}

const { eyebrow, title, subtitle, primary, secondary, align = 'left' } = Astro.props;
---

<section class:list={['page-hero', align === 'center' && 'page-hero--center']} data-reveal-group>
	<div class="container page-hero__inner">
		<div class="page-hero__content">
			{eyebrow && <p class="eyebrow">{eyebrow}</p>}
			<h1>{title}</h1>
			<p class="page-hero__subtitle">{subtitle}</p>
			{(primary || secondary) && (
				<div class="button-row">
					{primary && <a class="button button-primary" href={primary.href}>{primary.label}</a>}
					{secondary && <a class="button button-secondary" href={secondary.href}>{secondary.label}</a>}
				</div>
			)}
		</div>
		<slot />
	</div>
</section>
