---
export interface Props {
  title: string;
  eyebrow?: string;
}

const { title, eyebrow = 'Checklist' } = Astro.props;
const sectionId = `checklist-${crypto.randomUUID()}`;
---

<section class="checklist-section" aria-labelledby={sectionId} data-reveal>
  <div class="checklist-shell">
    <div class="checklist-header">
      <p class="eyebrow">{eyebrow}</p>
      <h2 id={sectionId}>{title}</h2>
    </div>
    <div class="checklist-body">
      <slot />
    </div>
  </div>
</section>

<style>
  .checklist-section {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }

  .checklist-shell {
    position: relative;
    display: grid;
    gap: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    background: var(--surface);
    backdrop-filter: blur(10px);
    overflow: hidden;
  }

  .checklist-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at 0% 0%, var(--brand-surface), transparent 55%);
    pointer-events: none;
  }

  .checklist-header,
  .checklist-body {
    position: relative;
  }

  .checklist-header h2 {
    font-size: var(--text-xl);
  }

  .checklist-body :global(p),
  .checklist-body :global(li) {
    color: var(--text-muted);
  }

  .checklist-header {
    display: grid;
    gap: 0.45rem;
  }

  .checklist-header h2 {
    margin: 0;
  }

  .checklist-body :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }

  .checklist-body :global(li) {
    position: relative;
    padding-left: 1.8rem;
    margin: 0;
  }

  .checklist-body :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--brand-500);
    box-shadow: 0 0 0 4px var(--brand-surface);
  }

  .checklist-body :global(p:first-child),
  .checklist-body :global(ul:first-child) {
    margin-top: 0;
  }

  .checklist-body :global(*:last-child) {
    margin-bottom: 0;
  }

  @media (min-width: 50rem) {
    .checklist-shell {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      align-items: start;
    }
  }
</style>
