---
export interface Props {
  title: string;
  eyebrow?: string;
}

const { title, eyebrow = 'Steps' } = Astro.props;
const sectionId = `steps-${crypto.randomUUID()}`;
---

<section class="steps-section" aria-labelledby={sectionId} data-reveal>
  <div class="steps-shell">
    <div class="steps-header">
      <p class="eyebrow">{eyebrow}</p>
      <h2 id={sectionId}>{title}</h2>
    </div>
    <div class="steps-body">
      <slot />
    </div>
  </div>
</section>

<style>
  .steps-section {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }

  .steps-shell {
    display: grid;
    gap: 1.4rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    border-radius: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--primary-500) 12%, rgba(255, 255, 255, 0.92));
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.8)),
      radial-gradient(circle at bottom left, color-mix(in srgb, var(--primary-300) 16%, transparent), transparent 42%);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
  }

  .steps-header {
    display: grid;
    gap: 0.45rem;
  }

  .steps-header h2 {
    margin: 0;
  }

  .steps-body :global(ol) {
    counter-reset: step-counter;
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .steps-body :global(li) {
    position: relative;
    padding: 0.15rem 0 0.15rem 3rem;
    margin: 0;
    min-height: 2.2rem;
  }

  .steps-body :global(li)::before {
    counter-increment: step-counter;
    content: counter(step-counter);
    position: absolute;
    left: 0;
    top: 0;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 700;
    color: white;
    background: linear-gradient(135deg, var(--primary-500), var(--primary-700));
    box-shadow: 0 10px 24px color-mix(in srgb, var(--primary-500) 26%, transparent);
  }

  .steps-body :global(*:first-child) {
    margin-top: 0;
  }

  .steps-body :global(*:last-child) {
    margin-bottom: 0;
  }

  @media (min-width: 50rem) {
    .steps-shell {
      grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
      align-items: start;
    }
  }
</style>
