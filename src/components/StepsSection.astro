---
export interface Props {
  title: string;
  eyebrow?: string;
}

const { title, eyebrow = 'Steps' } = Astro.props;
const sectionId = `steps-${crypto.randomUUID()}`;
---

<section class="steps-section" aria-labelledby={sectionId} data-reveal>
  <div class="steps-shell">
    <div class="steps-header">
      <p class="eyebrow">{eyebrow}</p>
      <h2 id={sectionId}>{title}</h2>
    </div>
    <div class="steps-body">
      <slot />
    </div>
  </div>
</section>

<style>
  .steps-section {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }

  .steps-shell {
    position: relative;
    display: grid;
    gap: 1.4rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-subtle);
    background: var(--surface);
    backdrop-filter: blur(10px);
    overflow: hidden;
  }

  .steps-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at 100% 100%, var(--brand-surface), transparent 50%);
    pointer-events: none;
  }

  .steps-header, .steps-body { position: relative; }
  .steps-header h2 { font-size: var(--text-xl); }

  .steps-header {
    display: grid;
    gap: 0.45rem;
  }

  .steps-header h2 {
    margin: 0;
  }

  .steps-body :global(ol) {
    counter-reset: step-counter;
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .steps-body :global(li) {
    position: relative;
    padding: 0.15rem 0 0.15rem 3rem;
    margin: 0;
    min-height: 2.2rem;
  }

  .steps-body :global(li)::before {
    counter-increment: step-counter;
    content: counter(step-counter);
    position: absolute;
    left: 0;
    top: 0;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--brand-contrast);
    background: var(--brand-500);
    box-shadow: 0 6px 16px color-mix(in srgb, var(--brand-500) 30%, transparent);
  }

  .steps-body :global(li),
  .steps-body :global(p) {
    color: var(--text-muted);
  }

  .steps-body :global(*:first-child) {
    margin-top: 0;
  }

  .steps-body :global(*:last-child) {
    margin-bottom: 0;
  }

  @media (min-width: 50rem) {
    .steps-shell {
      grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
      align-items: start;
    }
  }
</style>
