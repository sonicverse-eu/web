---
interface ProductMetric {
	value: string;
	label: string;
}

interface ProductData {
	title: string;
	tagline: string;
	summary: string;
	audience: string;
	category: string;
	status: 'shipping' | 'pilot' | 'roadmap';
	primaryCtaLabel: string;
	outcomes: string[];
	metrics: ProductMetric[];
}

export interface Props {
	product: {
		id: string;
		data: ProductData;
	};
	compact?: boolean;
}

const { product, compact = false } = Astro.props;
const slug = product.id.replace(/\.(md|mdoc)$/, '');
---

<article class:list={['product-card', compact && 'product-card--compact']} data-reveal>
	<div class="product-card__head">
		<div>
			<p class="product-card__category">{product.data.category}</p>
			<h3>{product.data.title}</h3>
		</div>
		<span class={`status-pill status-pill--${product.data.status}`}>{product.data.status}</span>
	</div>

	<p class="product-card__tagline">{product.data.tagline}</p>
	<p class="product-card__summary">{product.data.summary}</p>
	<p class="product-card__audience"><strong>Best for:</strong> {product.data.audience}</p>

	<div class="product-card__metrics">
		{product.data.metrics.slice(0, 2).map((metric) => (
			<div>
				<strong>{metric.value}</strong>
				<span>{metric.label}</span>
			</div>
		))}
	</div>

	{!compact && (
		<ul class="product-card__list">
			{product.data.outcomes.slice(0, 3).map((item) => <li>{item}</li>)}
		</ul>
	)}

	<div class="button-row">
		<a class="button button-primary" href={`/products/${slug}/`}>Learn more</a>
		<a class="button button-secondary" href="/contact">{product.data.primaryCtaLabel}</a>
	</div>
</article>
