---
import brandIcon from '../assets/brand/2.svg';
---

<footer class="site-footer" transition:persist>
  <div class="container footer-grid">
    <div>
      <div class="footer-brand">
        <img class="footer-brand-icon" src={brandIcon.src} alt="Sonicverse logo" />
        <h2>Sonicverse</h2>
      </div>
      <p>
        Open source tools for modern sonic products. Built in public with contributors around the
        world.
      </p>
    </div>
    <div>
      <h3>Navigate</h3>
      <ul>
        <li><a href="/projects">Projects</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/community">Community</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </div>
    <div>
      <h3>Connect</h3>
      <ul>
        <li><a href="https://github.com/rikvisser-dev">GitHub</a></li>
        <li><a href="mailto:hello@sonicverse.dev">hello@sonicverse.dev</a></li>
      </ul>
    </div>
  </div>
</footer>
