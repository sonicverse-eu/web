---
// Theme toggle: flips data-theme between 'light' and 'dark', persists to localStorage.
// The pre-paint script in Layout.astro initializes the theme to avoid FOUC.
---

<button
	type="button"
	class="theme-toggle"
	aria-label="Toggle color theme"
	data-theme-toggle
>
	<svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<circle cx="12" cy="12" r="4"></circle>
		<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
	</svg>
	<svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"></path>
	</svg>
</button>

<script>
	declare global {
		interface Window {
			__sonicverseThemeBound?: boolean;
		}
	}

	const STORAGE_KEY = 'sv-theme';

	const applyTheme = (theme: 'light' | 'dark') => {
		document.documentElement.setAttribute('data-theme', theme);
		try {
			localStorage.setItem(STORAGE_KEY, theme);
		} catch {
			/* ignore */
		}
	};

	const onClick = (event: Event) => {
		const target = event.target as Element | null;
		if (!target?.closest('[data-theme-toggle]')) return;
		const current = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
		applyTheme(current === 'dark' ? 'light' : 'dark');
	};

	if (!window.__sonicverseThemeBound) {
		document.addEventListener('click', onClick);
		window.__sonicverseThemeBound = true;
	}
</script>
