---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';

export async function getStaticPaths() {
	const products = await getCollection('projects');
	return products.map((product) => ({
		params: { slug: product.id.replace(/\.(md|mdoc)$/, '') },
		props: { product }
	}));
}

const { product } = Astro.props;
const productSlug = product.id.replace(/\.(md|mdoc)$/, '');
---

<Layout
	title={`${product.data.title} | Sonicverse`}
	description={product.data.summary}
	currentPath={`/products/${productSlug}/`}
>
	<PageHero
		eyebrow={product.data.category}
		title={product.data.title}
		subtitle={product.data.tagline}
		primary={{ label: product.data.primaryCtaLabel, href: product.data.primaryCtaHref }}
		secondary={product.data.secondaryCtaLabel && product.data.secondaryCtaHref
			? { label: product.data.secondaryCtaLabel, href: product.data.secondaryCtaHref }
			: undefined}
	>
		<div class="page-hero__aside" data-reveal>
			<div class="product-summary-card">
				<span class={`status-pill status-pill--${product.data.status}`}>{product.data.status}</span>
				<h2>{product.data.summary}</h2>
				<p><strong>Best for:</strong> {product.data.audience}</p>
			</div>
		</div>
	</PageHero>

	<section class="container section-gap">
		<div class="outcome-grid">
			{product.data.metrics.map((metric) => (
				<article class="metric-card" data-reveal>
					<strong>{metric.value}</strong>
					<span>{metric.label}</span>
				</article>
			))}
		</div>
	</section>

	<section class="container section-gap product-detail-layout">
		<div class="product-detail-main">
			<div class="section-head" data-reveal>
				<p class="eyebrow">Outcomes</p>
				<h2>What this product helps your team achieve</h2>
			</div>
			<div class="feature-list">
				{product.data.outcomes.map((item) => (
					<article class="feature-item" data-reveal>
						<p>{item}</p>
					</article>
				))}
			</div>

			<div class="section-head" data-reveal>
				<p class="eyebrow">Capabilities</p>
				<h2>How the product is structured</h2>
			</div>
			<div class="capability-grid">
				{product.data.capabilities.map((capability) => (
					<article class="capability-card" data-reveal>
						<h3>{capability.title}</h3>
						<p>{capability.description}</p>
					</article>
				))}
			</div>
		</div>

		<aside class="product-detail-sidebar" data-reveal>
			<div class="sidebar-card">
				<p class="eyebrow">Best fit</p>
				<ul class="check-list">
					{product.data.fit.map((item) => <li>{item}</li>)}
				</ul>
			</div>
			<div class="sidebar-card">
				<p class="eyebrow">Proof points</p>
				<ul class="check-list">
					{product.data.proofPoints.map((item) => <li>{item}</li>)}
				</ul>
				{product.data.repoUrl && <a class="text-link" href={product.data.repoUrl}>View the repository</a>}
			</div>
		</aside>
	</section>

	<section class="container section-gap">
		<div class="testimonial-panel" data-reveal>
			<p class="eyebrow">Field signal</p>
			<blockquote>{product.data.testimonial.quote}</blockquote>
			<p>{product.data.testimonial.author}</p>
			<span>{product.data.testimonial.role}</span>
		</div>
	</section>

	<section class="container section-gap">
		<div class="cta-panel" data-reveal>
			<p class="eyebrow">Next step</p>
			<h2>See how {product.data.title} fits your team, architecture, and rollout plan.</h2>
			<p>We can help you evaluate a self-serve adoption path, a supported implementation, or a launch-partner conversation.</p>
			<div class="button-row">
				<a class="button button-primary" href={product.data.primaryCtaHref}>{product.data.primaryCtaLabel}</a>
				<a class="button button-secondary" href="/products">Back to all products</a>
			</div>
		</div>
	</section>
</Layout>
