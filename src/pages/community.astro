---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const pageEntries = await getCollection('pages');
const page = pageEntries.find((entry) => /(^|\/)community(\.md|\.mdoc)?$/.test(entry.id));

if (!page) {
	throw new Error('Missing community page content at src/content/pages/community.mdoc');
}

const pillars = [
	'Transparent governance and public trade-offs',
	'Contributor pathways that welcome non-maintainers',
	'Documentation and architecture notes built in public',
	'Roadmap collaboration that strengthens product clarity'
];
---

<Layout
	title={page.data.seoTitle ?? page.data.title}
	description={page.data.seoDescription ?? page.data.description}
	image={page.data.seoImage}
	currentPath="/community"
>
	<PageHero
		eyebrow={page.data.eyebrow}
		title={page.data.heroTitle}
		subtitle={page.data.heroSubtitle}
		primary={{ label: page.data.ctaLabel!, href: page.data.ctaHref! }}
	/>

	<section class="container section-gap">
		<div class="product-grid product-grid--compact">
			{pillars.map((pillar) => (
				<article class="product-card product-card--compact" data-reveal>
					<div class="product-card__head">
						<div>
							<p class="product-card__category">Open source principle</p>
							<h3>{pillar}</h3>
						</div>
					</div>
				</article>
			))}
		</div>
	</section>
</Layout>
