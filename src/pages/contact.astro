---
import { actions, isInputError } from 'astro:actions';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { getValidThreadId } from '../utils/contact';

export const prerender = false;

const pageEntries = await getCollection('pages');
const page = pageEntries.find((entry) => /(^|\/)contact(\.md|\.mdoc|\.mdx)?$/.test(entry.id));

if (!page) {
	throw new Error('Missing contact page content at src/content/pages/contact.mdoc');
}

const actionResult = Astro.getActionResult(actions.sendMail);
const fieldErrors = isInputError(actionResult?.error) ? actionResult.error.fields : undefined;
const categories = page.data.contactCategories ?? [];

let submittedData: FormData | undefined;

if (Astro.request.method === 'POST') {
	try {
		submittedData = await Astro.request.clone().formData();
	} catch {
		submittedData = undefined;
	}
}

const getSubmittedValue = (name: string) => {
	const value = submittedData?.get(name);
	return typeof value === 'string' ? value : '';
};

const formValues = {
	name: getSubmittedValue('name'),
	email: getSubmittedValue('email'),
	company: getSubmittedValue('company'),
	category: getSubmittedValue('category'),
	categoryLabel: getSubmittedValue('categoryLabel'),
	threadId: getSubmittedValue('threadId'),
	detailsUrl: getSubmittedValue('detailsUrl'),
	message: getSubmittedValue('message')
};

const formSucceeded = Boolean(actionResult?.data?.ok);
const successThreadId = formSucceeded ? actionResult?.data?.threadId ?? '' : '';
const selectedCategory = categories.find((category) => category.value === formValues.category) ?? categories[0];
const categoryLabel = selectedCategory?.label ?? formValues.categoryLabel ?? '';
const draftThreadId = formSucceeded ? successThreadId : getValidThreadId(formValues.threadId);
const actionErrorMessage = actionResult?.error?.message ?? '';
---

<Layout
	title={page.data.seoTitle ?? page.data.title}
	description={page.data.seoDescription ?? page.data.description}
	image={page.data.seoImage}
	currentPath="/contact"
>
	<PageHero
		eyebrow={page.data.eyebrow}
		title={page.data.heroTitle}
		subtitle={page.data.heroSubtitle}
		primary={{ label: page.data.ctaLabel!, href: page.data.ctaHref! }}
	/>

	<section class="container section-gap contact-layout">
		<form class="contact-card" method="POST" action={actions.sendMail} novalidate data-reveal>
			<div class="contact-card__head">
				<p class="eyebrow">{page.data.contactFormKicker}</p>
				<h2>{page.data.contactFormTitle}</h2>
				<p>{page.data.contactFormSubtitle}</p>
			</div>

			{formSucceeded && (
				<p class="form-status form-status-success" role="status">
					Message sent. Use thread ID <strong>{successThreadId}</strong> in any follow-up.
				</p>
			)}

			{actionErrorMessage && (
				<p class="form-status form-status-error" role="alert">{actionErrorMessage}</p>
			)}

			<input class="contact-honeypot" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
			<input type="hidden" name="threadId" value={draftThreadId} />
			<input type="hidden" name="categoryLabel" value={categoryLabel} />

			<div class="contact-field-grid">
				<label class="contact-field">
					<span>Name</span>
					<input id="name" name="name" type="text" required value={formValues.name} />
					{fieldErrors?.name && <small class="field-error">{fieldErrors.name[0]}</small>}
				</label>
				<label class="contact-field">
					<span>Work email</span>
					<input id="email" name="email" type="email" required value={formValues.email} />
					{fieldErrors?.email && <small class="field-error">{fieldErrors.email[0]}</small>}
				</label>
			</div>

			<label class="contact-field">
				<span>Company or organisation</span>
				<input id="company" name="company" type="text" value={formValues.company} />
			</label>

			<label class="contact-field">
				<span>What do you need?</span>
				<select id="category" name="category" required>
					{categories.map((category, index) => (
						<option value={category.value} selected={formValues.category ? formValues.category === category.value : index === 0}>
							{category.label}
						</option>
					))}
				</select>
				{fieldErrors?.category && <small class="field-error">{fieldErrors.category[0]}</small>}
			</label>

			<label class="contact-field">
				<span>Useful link</span>
				<input id="detailsUrl" name="detailsUrl" type="url" value={formValues.detailsUrl} placeholder="https://..." />
			</label>

			<label class="contact-field">
				<span>Context</span>
				<textarea id="message" name="message" rows="7" required>{formValues.message}</textarea>
				{fieldErrors?.message && <small class="field-error">{fieldErrors.message[0]}</small>}
			</label>

			<button class="button button-primary" type="submit">Send request</button>
		</form>

		<aside class="contact-side" data-reveal>
			<div class="sidebar-card">
				<p class="eyebrow">{page.data.supportTitle}</p>
				<h2>{page.data.supportDescription}</h2>
				<div class="contact-route-list">
					{page.data.supportLinks?.map((link) => (
						<a class="contact-route" href={link.href}>
							<strong>{link.label}</strong>
							<span>{link.value}</span>
						</a>
					))}
				</div>
			</div>
			<div class="sidebar-card">
				<p class="eyebrow">What to include</p>
				<ul class="check-list">
					{page.data.supportNotes?.map((note) => <li>{note}</li>)}
				</ul>
			</div>
		</aside>
	</section>
</Layout>
