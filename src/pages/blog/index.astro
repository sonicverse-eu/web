---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const pageEntries = await getCollection('pages');
const page = pageEntries.find((entry) =>
  /(^|\/)blog(\.md|\.mdoc)?$/.test(entry.id)
);

if (!page) {
  throw new Error('Missing blog page content at src/content/pages/blog.mdoc');
}

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
  title={page.data.seoTitle ?? page.data.title}
  description={page.data.seoDescription ?? page.data.description}
  image={page.data.seoImage}
  currentPath="/blog"
>
  <section class="hero container" data-reveal-group>
    <div class="hero-glow" aria-hidden="true"></div>
    {page.data.eyebrow && <p class="eyebrow">{page.data.eyebrow}</p>}
    <h1 class="gradient-text">{page.data.heroTitle}</h1>
    <p class="hero-subtitle">{page.data.heroSubtitle}</p>
  </section>

  <section class="container section-gap" data-reveal>
    <div class="blog-list">
      {
        posts.map((post, index) => (
          <article class="blog-post-item" data-reveal data-reveal-delay={index * 0.07}>
            <div class="blog-post-meta">
              <p class="eyebrow">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </p>
              {post.data.tags.length > 0 && (
                <div class="tag-list">
                  {post.data.tags.map((tag: string) => <span>{tag}</span>)}
                </div>
              )}
            </div>
            <div class="blog-post-content">
              <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              <div class="button-row">
                <a class="button button-ghost" href={`/blog/${post.id}`}>{page.data.blogArticleCtaLabel ?? 'Read article'}</a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
