---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
  title="Sonicverse Blog"
  description="Updates from the Sonicverse open source initiative."
  currentPath="/blog"
>
  <section class="hero container" data-reveal>
    <p class="eyebrow">Updates</p>
    <h1>Product notes, roadmap, and community progress.</h1>
    <p class="hero-subtitle">
      Every post is written in Markdoc so your team can update content quickly without changing layout
      code.
    </p>
  </section>

  <section class="container section-gap" data-reveal>
    <div class="card-grid">
      {
        posts.map((post, index) => (
          <article class="feature-card" data-reveal data-reveal-delay={index * 0.09}>
            <p class="eyebrow">{post.data.pubDate.toLocaleDateString('en-US')}</p>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <a class="button button-ghost" href={`/blog/${post.id}`}>Read article</a>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
