---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
	formatBlogDate,
	getBlogTagSummaries,
	getReadingTimeMinutes,
	sortBlogPosts
} from '../../utils/blog';

const pageEntries = await getCollection('pages');
const page = pageEntries.find((entry) =>
  /(^|\/)blog(\.md|\.mdoc)?$/.test(entry.id)
);

if (!page) {
  throw new Error('Missing blog page content at src/content/pages/blog.mdoc');
}

const posts = sortBlogPosts(await getCollection('blog', ({ data }) => !data.draft));
const [featuredPost, ...archivePosts] = posts;
const tagSummaries = getBlogTagSummaries(posts);
---

<Layout
  title={page.data.seoTitle ?? page.data.title}
  description={page.data.seoDescription ?? page.data.description}
  image={page.data.seoImage}
  currentPath="/blog"
>
  <section class="hero container" data-reveal-group>
    <div class="hero-glow" aria-hidden="true"></div>
    {page.data.eyebrow && <p class="eyebrow">{page.data.eyebrow}</p>}
    <h1 class="gradient-text">{page.data.heroTitle}</h1>
    <p class="hero-subtitle">{page.data.heroSubtitle}</p>
    {tagSummaries.length > 0 && (
      <div class="tag-list" aria-label="Blog topics">
        {tagSummaries.map((summary) => <span>{summary.tag}</span>)}
      </div>
    )}
  </section>

  {featuredPost && (
    <section class="container section-gap blog-grid-shell" data-reveal>
      <article class="blog-featured-card" data-reveal>
        <p class="eyebrow">{page.data.blogFeaturedLabel ?? 'Featured story'}</p>
        <div class="blog-featured-meta">
          <span>{formatBlogDate(featuredPost.data.pubDate)}</span>
          <span>{featuredPost.data.author}</span>
          <span>{getReadingTimeMinutes(featuredPost.body)} min read</span>
        </div>
        <h2>
          <a href={`/blog/${featuredPost.id}`}>{featuredPost.data.title}</a>
        </h2>
        <p>{featuredPost.data.description}</p>
        {featuredPost.data.tags.length > 0 && (
          <div class="tag-list" aria-label="Featured topics">
            {featuredPost.data.tags.map((tag: string) => <span>{tag}</span>)}
          </div>
        )}
        <div class="button-row">
          <a class="button" href={`/blog/${featuredPost.id}`}>
            {page.data.blogArticleCtaLabel ?? 'Read article'}
          </a>
        </div>
      </article>

      <aside class="blog-topics-panel" data-reveal data-reveal-delay="0.08" aria-labelledby="blog-topics-title">
        <div class="blog-panel-header">
          <p class="eyebrow">{page.data.blogTopicsLabel ?? 'Browse topics'}</p>
          <h2 id="blog-topics-title">A quick way into the archive.</h2>
        </div>
        <div class="blog-topic-grid">
          {tagSummaries.slice(0, 5).map((summary) => (
            <a class="blog-topic-chip" href={`#topic-${summary.tag.toLowerCase().replace(/\s+/g, '-')}`}>
              <strong>{summary.tag}</strong>
              <span>
                {summary.count} {summary.count === 1 ? 'post' : 'posts'}
              </span>
            </a>
          ))}
        </div>
      </aside>
    </section>
  )}

  <section class="container section-gap blog-archive-shell" data-reveal>
    <div class="blog-archive-header" data-reveal>
      <div>
        <p class="eyebrow">{page.data.blogArchiveTitle ?? 'Latest from Sonicverse'}</p>
        <h2>{page.data.blogArchiveDescription ?? 'Editorial updates from the Sonicverse ecosystem.'}</h2>
      </div>
    </div>

    <div class="blog-list">
      {(archivePosts.length > 0 ? archivePosts : posts).map((post, index) => (
        <article class="blog-post-item blog-post-item-rich" data-reveal data-reveal-delay={index * 0.07}>
          <div
            class="blog-post-meta"
            id={post.data.tags[0] ? `topic-${post.data.tags[0].toLowerCase().replace(/\s+/g, '-')}` : undefined}
          >
            <p class="eyebrow">{formatBlogDate(post.data.pubDate)}</p>
            <p>{post.data.author}</p>
            <p>{getReadingTimeMinutes(post.body)} min read</p>
          </div>
          <div class="blog-post-content">
            <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="tag-list" aria-label={`Topics for ${post.data.title}`}>
                {post.data.tags.map((tag: string) => <span>{tag}</span>)}
              </div>
            )}
            <div class="button-row">
              <a class="button button-ghost" href={`/blog/${post.id}`}>
                {page.data.blogArticleCtaLabel ?? 'Read article'}
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
