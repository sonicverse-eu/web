---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
	formatBlogDate,
	getAdjacentBlogPosts,
	getReadingTimeMinutes,
	getRelatedBlogPosts,
	sortBlogPosts
} from '../../utils/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const pageEntries = await getCollection('pages');
const page = pageEntries.find((entry) =>
  /(^|\/)blog(\.md|\.mdoc)?$/.test(entry.id)
);

if (!page) {
  throw new Error('Missing blog page content at src/content/pages/blog.mdoc');
}

const allPosts = sortBlogPosts(await getCollection('blog', ({ data }) => !data.draft));
const { newerPost, olderPost } = getAdjacentBlogPosts(allPosts, post.id);
const relatedPosts = getRelatedBlogPosts(allPosts, post);
const readingTime = getReadingTimeMinutes(post.body);
const { Content } = await render(post);
---

<Layout 
  title={post.data.title} 
  description={post.data.description} 
  currentPath={`/blog/${post.id}`}
  image={post.data.image}
  ogType="article"
  author={post.data.author}
  pubDate={post.data.pubDate.toISOString()}
  tags={post.data.tags}
>
  <article class="container section-gap blog-article-shell" data-reveal>
    <header class="blog-article-hero" data-reveal-group>
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/blog">Blog</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{post.data.title}</span>
      </nav>
      <p class="eyebrow">{formatBlogDate(post.data.pubDate)}</p>
      <h1>{post.data.title}</h1>
      <p class="hero-subtitle">{post.data.description}</p>
      <div class="blog-article-meta" aria-label="Article metadata">
        <span>{post.data.author}</span>
        <span>{readingTime} min read</span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="tag-list" aria-label="Article topics">
          {post.data.tags.map((tag: string) => <a href={`/blog#topic-${tag.toLowerCase().replace(/\s+/g, '-')}`}>{tag}</a>)}
        </div>
      )}
    </header>

    <div class="blog-article-body">
      <div class="prose blog-article-prose">
        <Content frontmatter={post.data} />
      </div>
    </div>

    {(newerPost || olderPost) && (
      <section class="blog-article-footer">
        <div class="blog-related-header">
          <p class="eyebrow">{page.data.blogNavigationLabel ?? 'Continue reading'}</p>
          <h2>Next in the archive.</h2>
        </div>
        <div class="blog-continue-grid">
          {newerPost && (
            <article class="blog-related-card">
              <p class="eyebrow">Newer post</p>
              <h3><a href={`/blog/${newerPost.id}`}>{newerPost.data.title}</a></h3>
              <p>{newerPost.data.description}</p>
            </article>
          )}
          {olderPost && (
            <article class="blog-related-card">
              <p class="eyebrow">Older post</p>
              <h3><a href={`/blog/${olderPost.id}`}>{olderPost.data.title}</a></h3>
              <p>{olderPost.data.description}</p>
            </article>
          )}
        </div>
      </section>
    )}

    <section class="blog-related-shell">
      <div class="blog-related-header">
        <p class="eyebrow">{page.data.blogRelatedTitle ?? 'Related posts'}</p>
        <h2>More on this topic.</h2>
      </div>
      {relatedPosts.length > 0 ? (
        <div class="blog-related-grid">
          {relatedPosts.slice(0, 2).map((relatedPost) => (
            <article class="blog-related-card">
              <p class="eyebrow">{formatBlogDate(relatedPost.data.pubDate)}</p>
              <h3><a href={`/blog/${relatedPost.id}`}>{relatedPost.data.title}</a></h3>
              <p>{relatedPost.data.description}</p>
            </article>
          ))}
        </div>
      ) : (
        <div class="blog-related-empty">
          <p>No related posts yet for these topics.</p>
          <a class="button button-ghost" href="/blog">
            {page.data.blogBrowseAllLabel ?? 'Browse all posts'}
          </a>
        </div>
      )}
    </div>
  </article>
</Layout>
