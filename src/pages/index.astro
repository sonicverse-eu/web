---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BentoGrid from '../components/BentoGrid.astro';
import MetricsBand from '../components/MetricsBand.astro';
import LogoCloud from '../components/LogoCloud.astro';
import CTABand from '../components/CTABand.astro';

const pageEntries = await getCollection('pages');
const home = pageEntries.find((entry) =>
	/(^|\/)home(\.md|\.mdoc)?$/.test(entry.id)
);

if (!home) {
  throw new Error('Missing home page content at src/content/pages/home.mdoc');
}

const { Content } = await render(home);
const features = (await getCollection('features')).sort((a, b) => a.data.order - b.data.order);
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order).slice(0, 3);
const faqs = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order).slice(0, 2);
const getProjectSlug = (project: (typeof projects)[number]) =>
	project.id.replace(/\.(md|mdoc)$/, '');

const bentoFeatures = features.map((f) => ({
	title: f.data.title,
	summary: f.data.summary,
	eyebrow: f.data.eyebrow
}));
---

<Layout
	title={home.data.seoTitle ?? home.data.title}
	description={home.data.seoDescription ?? home.data.description}
	image={home.data.seoImage}
	currentPath="/"
>
	<section class="hero container" data-reveal-group>
		<div class="hero-glow" aria-hidden="true"></div>
		{home.data.eyebrow && <p class="eyebrow">{home.data.eyebrow}</p>}
		<h1 class="gradient-text">{home.data.heroTitle}</h1>
		<p class="hero-subtitle">{home.data.heroSubtitle}</p>
		<div class="button-row">
			{home.data.ctaHref && home.data.ctaLabel && (
				<a class="button button-primary" href={home.data.ctaHref}>{home.data.ctaLabel}</a>
			)}
			{home.data.secondaryCtaHref && home.data.secondaryCtaLabel && (
				<a class="button button-ghost" href={home.data.secondaryCtaHref}>{home.data.secondaryCtaLabel}</a>
			)}
		</div>
	</section>

	{home.data.partners && home.data.partners.length > 0 && (
		<section class="container section-gap">
			<LogoCloud label={home.data.partnersLabel} partners={home.data.partners} />
		</section>
	)}

	<section class="container section-gap prose" data-reveal>
		<Content frontmatter={home.data} />
	</section>

	<section class="container section-gap">
		<SectionHeading
			eyebrow={home.data.featureSectionEyebrow}
			title={home.data.featureSectionTitle}
		/>
		<BentoGrid features={bentoFeatures} />
	</section>

	{home.data.metrics && home.data.metrics.length > 0 && (
		<section class="container section-gap">
			<MetricsBand metrics={home.data.metrics} />
		</section>
	)}

	<section class="container section-gap">
		<SectionHeading
			eyebrow={home.data.projectSectionEyebrow}
			title={home.data.projectSectionTitle}
		/>
		<div class="card-grid" data-reveal-group>
			{
				projects.map((project, index) => (
					<article class="feature-card" data-reveal data-reveal-delay={(index * 0.09).toFixed(2)}>
						<span class={`badge badge-${project.data.status}`}>{project.data.status}</span>
						<h3>{project.data.title}</h3>
						<p>{project.data.summary}</p>
						<a class="button button-ghost" href={`/projects/${getProjectSlug(project)}/`}>{home.data.projectLinkLabel ?? 'View project'} →</a>
					</article>
				))
			}
		</div>
	</section>

	<section class="container section-gap">
		<SectionHeading
			eyebrow={home.data.faqSectionEyebrow}
			title={home.data.faqSectionTitle}
		/>
		<div class="faq-list" data-reveal-group>
			{
				faqs.map((item, index) => (
					<article class="faq-item" data-reveal data-reveal-delay={(index * 0.09).toFixed(2)}>
						<h3>{item.data.question}</h3>
						<p>{item.data.answer}</p>
					</article>
				))
			}
		</div>
	</section>

	{home.data.ctaBand && (
		<section class="container section-gap">
			<CTABand
				eyebrow={home.data.ctaBand.eyebrow}
				title={home.data.ctaBand.title}
				subtitle={home.data.ctaBand.subtitle}
				primary={home.data.ctaBand.primary}
				secondary={home.data.ctaBand.secondary}
			/>
		</section>
	)}
</Layout>
