---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BentoGrid from '../components/BentoGrid.astro';
import MetricsBand from '../components/MetricsBand.astro';
import CTABand from '../components/CTABand.astro';
import ProductCard from '../components/ProductCard.astro';

const pageEntries = await getCollection('pages');
const home = pageEntries.find((entry) =>
	/(^|\/)home(\.md|\.mdoc)?$/.test(entry.id)
);

if (!home) {
  throw new Error('Missing home page content at src/content/pages/home.mdoc');
}

const { Content } = await render(home);
const features = (await getCollection('features')).sort((a, b) => a.data.order - b.data.order);
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const faqs = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order).slice(0, 3);
const getProjectSlug = (project: (typeof projects)[number]) =>
	project.id.replace(/\.(md|mdoc)$/, '');

const bentoFeatures = features.map((f) => ({
	title: f.data.title,
	summary: f.data.summary,
	eyebrow: f.data.eyebrow
}));

const projectAudiences: Record<string, string> = {
  'audio-streaming-stack': 'Independent broadcasters & community radio',
  'media-metadata-api': 'Podcast platforms & media archive teams',
  'broadcast-scheduler': 'Community radio & college stations',
};
---

<Layout
	title={home.data.seoTitle ?? home.data.title}
	description={home.data.seoDescription ?? home.data.description}
	image={home.data.seoImage}
	currentPath="/"
>
	<!-- ── HERO ────────────────────────────────────────────── -->
	<section class="hero-split container" data-reveal-group>
		<div class="hero-glow" aria-hidden="true" style="top: -5%; left: -5%;"></div>

		<div class="hero-split-copy">
			{home.data.eyebrow && <p class="eyebrow">{home.data.eyebrow}</p>}
			<h1 class="gradient-text">{home.data.heroTitle}</h1>
			<p class="hero-subtitle">{home.data.heroSubtitle}</p>

			<div class="button-row">
				{home.data.ctaHref && home.data.ctaLabel && (
					<a class="button button-primary" href={home.data.ctaHref}>{home.data.ctaLabel}</a>
				)}
				{home.data.secondaryCtaHref && home.data.secondaryCtaLabel && (
					<a class="button button-ghost" href={home.data.secondaryCtaHref}>{home.data.secondaryCtaLabel}</a>
				)}
			</div>
		</div>

		<div class="hero-split-visual" aria-hidden="true">
			<div class="hero-abstract">
				<!-- Gradient orbs -->
				<div class="hero-orb hero-orb--a"></div>
				<div class="hero-orb hero-orb--b"></div>
				<div class="hero-orb hero-orb--c"></div>
				<!-- Grid overlay -->
				<div class="hero-grid"></div>
				<!-- Geometric accents -->
				<svg class="hero-abstract-svg" viewBox="0 0 400 360" fill="none" xmlns="http://www.w3.org/2000/svg">
					<!-- Node ring -->
					<circle cx="200" cy="180" r="90" stroke="currentColor" stroke-width="0.75" stroke-dasharray="4 6" opacity="0.35" />
					<circle cx="200" cy="180" r="130" stroke="currentColor" stroke-width="0.5" stroke-dasharray="3 8" opacity="0.2" />
					<!-- Nodes -->
					<circle cx="200" cy="90" r="4" fill="currentColor" opacity="0.7" />
					<circle cx="290" cy="180" r="3" fill="currentColor" opacity="0.5" />
					<circle cx="200" cy="270" r="4" fill="currentColor" opacity="0.7" />
					<circle cx="110" cy="180" r="3" fill="currentColor" opacity="0.5" />
					<circle cx="263" cy="117" r="2.5" fill="currentColor" opacity="0.4" />
					<circle cx="263" cy="243" r="2.5" fill="currentColor" opacity="0.4" />
					<circle cx="137" cy="117" r="2.5" fill="currentColor" opacity="0.4" />
					<circle cx="137" cy="243" r="2.5" fill="currentColor" opacity="0.4" />
					<!-- Connection lines -->
					<line x1="200" y1="90" x2="263" y2="117" stroke="currentColor" stroke-width="0.6" opacity="0.25" />
					<line x1="263" y1="117" x2="290" y2="180" stroke="currentColor" stroke-width="0.6" opacity="0.25" />
					<line x1="200" y1="90" x2="137" y2="117" stroke="currentColor" stroke-width="0.6" opacity="0.25" />
					<line x1="137" y1="117" x2="110" y2="180" stroke="currentColor" stroke-width="0.6" opacity="0.25" />
					<!-- Center mark -->
					<circle cx="200" cy="180" r="16" fill="currentColor" opacity="0.08" />
					<circle cx="200" cy="180" r="7" fill="currentColor" opacity="0.18" />
					<circle cx="200" cy="180" r="2.5" fill="currentColor" opacity="0.9" />
					<!-- Outer orbit nodes (animated via CSS) -->
					<circle class="orbit-node" cx="200" cy="50" r="2" fill="currentColor" opacity="0.6" />
					<circle class="orbit-node-2" cx="350" cy="180" r="2" fill="currentColor" opacity="0.6" />
				</svg>
				<!-- Corner accents -->
				<div class="hero-abstract-corner hero-abstract-corner--tr"></div>
				<div class="hero-abstract-corner hero-abstract-corner--bl"></div>
			</div>
		</div>
	</section>

	<!-- ── PRODUCTS ────────────────────────────────────────── -->
	<section class="container section-gap" data-reveal>
		<div class="section-intro-row">
			<div class="section-intro">
				{home.data.projectSectionEyebrow && <p class="eyebrow">{home.data.projectSectionEyebrow}</p>}
				{home.data.projectSectionTitle && <h2>{home.data.projectSectionTitle}</h2>}
			</div>
			<a class="button button-ghost" href="/projects" style="flex-shrink:0;align-self:flex-end;">
				View all →
			</a>
		</div>
		<div class="product-grid" data-reveal-group>
			{projects.map((project, index) => (
				<ProductCard
					slug={getProjectSlug(project)}
					title={project.data.title}
					summary={project.data.summary}
					status={project.data.status}
					href={`/projects/${getProjectSlug(project)}/`}
					audience={projectAudiences[getProjectSlug(project)]}
					index={index}
				/>
			))}
		</div>
	</section>

	<!-- ── WHY SONICVERSE ──────────────────────────────────── -->
	{bentoFeatures.length > 0 && (
		<section class="container section-gap">
			<SectionHeading
				eyebrow={home.data.featureSectionEyebrow}
				title={home.data.featureSectionTitle}
			/>
			<BentoGrid features={bentoFeatures} />
		</section>
	)}

	<!-- ── FAQ ─────────────────────────────────────────────── -->
	{faqs.length > 0 && (
		<section class="container section-gap">
			<SectionHeading
				eyebrow={home.data.faqSectionEyebrow}
				title={home.data.faqSectionTitle}
			/>
			<div class="faq-list" data-reveal-group>
				{faqs.map((item, index) => (
					<article class="faq-item" data-reveal data-reveal-delay={(index * 0.09).toFixed(2)}>
						<h3>{item.data.question}</h3>
						<p>{item.data.answer}</p>
					</article>
				))}
			</div>
		</section>
	)}

	<!-- ── CTA BAND ────────────────────────────────────────── -->
	{home.data.ctaBand && (
		<section class="container section-gap">
			<CTABand
				eyebrow={home.data.ctaBand.eyebrow}
				title={home.data.ctaBand.title}
				subtitle={home.data.ctaBand.subtitle}
				primary={home.data.ctaBand.primary}
				secondary={home.data.ctaBand.secondary}
			/>
		</section>
	)}
</Layout>
