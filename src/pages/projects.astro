---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import CTABand from '../components/CTABand.astro';
import ProductCard from '../components/ProductCard.astro';

const pageEntries = await getCollection('pages');
const page = pageEntries.find((entry) =>
  /(^|\/)projects(\.md|\.mdoc)?$/.test(entry.id)
);

if (!page) {
  throw new Error('Missing projects page content at src/content/pages/projects.mdoc');
}

const { Content } = await render(page);
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const getProjectSlug = (project: (typeof projects)[number]) =>
  project.id.replace(/\.(md|mdoc)$/, '');

const projectAudiences: Record<string, string> = {
  'audio-streaming-stack': 'Independent broadcasters & community radio stations',
  'media-metadata-api': 'Podcast platforms & media archive teams',
  'broadcast-scheduler': 'Community radio & college broadcast stations',
};
---

<Layout
  title={page.data.seoTitle ?? page.data.title}
  description={page.data.seoDescription ?? page.data.description}
  image={page.data.seoImage}
  currentPath="/projects"
>
  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="hero container" data-reveal-group>
    <div class="hero-glow" aria-hidden="true"></div>
    {page.data.eyebrow && <p class="eyebrow">{page.data.eyebrow}</p>}
    <h1 class="gradient-text">{page.data.heroTitle}</h1>
    <p class="hero-subtitle">{page.data.heroSubtitle}</p>
    <div class="button-row">
      {page.data.ctaHref && page.data.ctaLabel && (
        <a class="button button-primary" href={page.data.ctaHref} target="_blank" rel="noopener noreferrer">
          {page.data.ctaLabel}
        </a>
      )}
    </div>
  </section>

  <!-- ── PRODUCT GRID ─────────────────────────────────────── -->
  <section class="container section-gap">
    <div class="section-intro">
      {page.data.projectSectionEyebrow && <p class="eyebrow">{page.data.projectSectionEyebrow}</p>}
      {page.data.projectSectionTitle && <h2>{page.data.projectSectionTitle}</h2>}
    </div>
    <div class="product-grid" data-reveal-group>
      {projects.map((project, index) => (
        <ProductCard
          slug={getProjectSlug(project)}
          title={project.data.title}
          summary={project.data.summary}
          status={project.data.status}
          href={`/projects/${getProjectSlug(project)}/`}
          audience={projectAudiences[getProjectSlug(project)]}
          index={index}
        />
      ))}
    </div>
  </section>

  <!-- ── MARKDOWN CONTENT ─────────────────────────────────── -->
  <section class="container prose section-gap" data-reveal style="max-width:52rem;">
    <Content frontmatter={page.data} />
  </section>
</Layout>
