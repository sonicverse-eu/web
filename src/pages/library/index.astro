---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const pageEntries = await getCollection('pages');
const page = pageEntries.find((entry) =>
  /(^|\/)library(\.md|\.mdoc)?$/.test(entry.id)
);

if (!page) {
  throw new Error('Missing library page content at src/content/pages/library.mdoc');
}

const entries = (await getCollection('library', ({ data }) => !data.draft)).sort(
  (a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0)
);
---

<Layout
  title={page.data.seoTitle ?? page.data.title}
  description={page.data.seoDescription ?? page.data.description}
  image={page.data.seoImage}
  currentPath="/library"
>
  <section class="hero container" data-reveal-group>
    {page.data.eyebrow && <p class="eyebrow">{page.data.eyebrow}</p>}
    <h1>{page.data.heroTitle}</h1>
    <p class="hero-subtitle">{page.data.heroSubtitle}</p>
  </section>

  <section class="container section-gap" data-reveal>
    <div class="blog-list">
      {
        entries.map((entry, index) => (
          <article class="blog-post-item" data-reveal data-reveal-delay={index * 0.07}>
            <div class="blog-post-meta">
              {entry.data.pubDate && (
                <p class="eyebrow">
                  {entry.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                  })}
                </p>
              )}
              {entry.data.tags.length > 0 && (
                <div class="tag-list">
                  {entry.data.tags.map((tag: string) => <span>{tag}</span>)}
                </div>
              )}
            </div>
            <div class="blog-post-content">
              <h2><a href={`/library/${entry.id}`}>{entry.data.title}</a></h2>
              <p>{entry.data.description}</p>
              <div class="button-row">
                <a class="button button-ghost" href={`/library/${entry.id}`}>
                  {page.data.blogArticleCtaLabel ?? 'Read entry'}
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
