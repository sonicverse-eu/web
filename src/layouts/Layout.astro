---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { ClientRouter, slide } from 'astro:transitions';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  image?: string;
  ogType?: 'website' | 'article';
  author?: string;
  pubDate?: string;
  tags?: string[];
}

const site = Astro.site ?? new URL('https://sonicverse.dev');
const {
  title = 'Sonicverse | Open Source Initiative',
  description = 'Open source tools for building the future of collaborative sound experiences.',
  currentPath = '/',
	image = '/og-image.svg',
  ogType = 'website',
  author,
  pubDate,
  tags = []
} = Astro.props;

const canonicalURL = new URL(currentPath, site);
const absoluteImage = new URL(image, site);

const baseSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Sonicverse',
	url: site.toString(),
	logo: new URL('/favicon.svg', site).toString(),
  description: description,
  sameAs: []
};

let structuredData = baseSchema;

if (ogType === 'article' && author && pubDate) {
  structuredData = {
    '@context': 'https://schema.org',
    '@type': 'NewsArticle',
    headline: title,
    description: description,
    image: absoluteImage.toString(),
    datePublished: pubDate,
    author: {
      '@type': 'Person',
      name: author
    },
    publisher: {
      '@type': 'Organization',
      name: 'Sonicverse',
			logo: new URL('/favicon.svg', site).toString()
    }
  };
}
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="theme-color" content="#1a1a1a" />
		<link rel="canonical" href={canonicalURL} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Open Graph Meta Tags -->
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={absoluteImage} />
		<meta property="og:image:alt" content={title} />
		<meta property="og:site_name" content="Sonicverse" />
		
		<!-- Twitter Meta Tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURL} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={absoluteImage} />
		
		{/* Article-specific meta tags */}
		{ogType === 'article' && pubDate && (
			<>
				<meta property="article:published_time" content={pubDate} />
				{author && <meta property="article:author" content={author} />}
				{tags.map((tag) => (
					<meta property="article:tag" content={tag} />
				))}
			</>
		)}
		
		<!-- Preconnect to external domains for performance -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		
		<!-- Structured Data JSON-LD -->
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		<script>
			import { animate, inView, scroll } from 'motion';

			declare global {
				interface Window {
					__sonicverseMotionBound?: boolean;
					__sonicverseMotionCleanup?: Array<() => void>;
				}
			}

			const runSonicverseMotion = () => {
				const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				const revealElements = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));

				window.__sonicverseMotionCleanup?.forEach((cleanup) => cleanup());
				window.__sonicverseMotionCleanup = [];

				if (!revealElements.length) {
					return;
				}

				if (reduceMotion) {
					revealElements.forEach((element) => {
						element.style.opacity = '1';
						element.style.transform = 'none';
						element.style.filter = 'none';
					});
					return;
				}

				revealElements.forEach((element) => {
					element.style.opacity = '0';
					element.style.transform = 'translateY(18px) scale(0.985)';
					element.style.filter = 'blur(8px)';
				});

				const stopInView = inView(
					'[data-reveal]',
					(element) => {
						const target = element as HTMLElement;
						const delay = Number(target.getAttribute('data-reveal-delay') || '0');
						animate(
							target,
							{
								opacity: [0, 1],
								y: [18, 0],
								scale: [0.985, 1],
								filter: ['blur(8px)', 'blur(0px)']
							},
							{
								duration: 0.7,
								delay,
								ease: [0.22, 1, 0.36, 1]
							}
						);
					},
					{ margin: '0px 0px -8% 0px' }
				);

				const stopScroll = scroll((progress: number) => {
					document.documentElement.style.setProperty('--scroll-progress', progress.toFixed(4));
				});

				window.__sonicverseMotionCleanup.push(stopInView, stopScroll);
			};

			if (!window.__sonicverseMotionBound) {
				document.addEventListener('astro:page-load', runSonicverseMotion);
				window.__sonicverseMotionBound = true;
			}

			runSonicverseMotion();
		</script>
		<ClientRouter fallback="animate" />
		<title>{title}</title>
	</head>
	<body>
		<div class="background-atmosphere" aria-hidden="true"></div>
		<SiteHeader currentPath={currentPath} transition:persist />
		<main transition:name="page" transition:animate={slide({ duration: '0.4s' })}>
			<slot />
		</main>
		<SiteFooter transition:persist />
	</body>
</html>