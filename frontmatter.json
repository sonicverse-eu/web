{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.framework.id": "astro",
  "frontMatter.content.supportedFileTypes": [
    "md",
    "markdown",
    "mdx",
    "mdoc"
  ],
  "frontMatter.content.pageFolders": [
    {
      "title": "Pages",
      "path": "[[workspace]]/src/content/pages",
      "contentTypes": [
        "page"
      ]
    },
    {
      "title": "Blog",
      "path": "[[workspace]]/src/content/blog",
      "contentTypes": [
        "blog"
      ],
      "previewPath": "/blog"
    },
    {
      "title": "Features",
      "path": "[[workspace]]/src/content/features",
      "contentTypes": [
        "feature"
      ]
    },
    {
      "title": "Projects",
      "path": "[[workspace]]/src/content/projects",
      "contentTypes": [
        "project"
      ]
    },
    {
      "title": "FAQ",
      "path": "[[workspace]]/src/content/faq",
      "contentTypes": [
        "faq"
      ]
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "default",
      "pageBundle": false,
      "previewPath": null,
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string"
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string"
        },
        {
          "title": "Publishing date",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true
        },
        {
          "title": "Content preview",
          "name": "preview",
          "type": "image"
        },
        {
          "title": "Is in draft",
          "name": "draft",
          "type": "draft"
        },
        {
          "title": "Tags",
          "name": "tags",
          "type": "tags"
        },
        {
          "title": "Categories",
          "name": "categories",
          "type": "categories"
        },
        {
          "title": "seoTitle",
          "name": "seoTitle",
          "type": "string"
        },
        {
          "title": "seoDescription",
          "name": "seoDescription",
          "type": "string"
        },
        {
          "title": "seoImage",
          "name": "seoImage",
          "type": "image"
        },
        {
          "title": "eyebrow",
          "name": "eyebrow",
          "type": "string"
        },
        {
          "title": "heroTitle",
          "name": "heroTitle",
          "type": "string"
        },
        {
          "title": "heroSubtitle",
          "name": "heroSubtitle",
          "type": "string"
        },
        {
          "title": "ctaLabel",
          "name": "ctaLabel",
          "type": "string"
        },
        {
          "title": "ctaHref",
          "name": "ctaHref",
          "type": "string"
        },
        {
          "title": "secondaryCtaLabel",
          "name": "secondaryCtaLabel",
          "type": "string"
        },
        {
          "title": "secondaryCtaHref",
          "name": "secondaryCtaHref",
          "type": "string"
        },
        {
          "title": "featureSectionEyebrow",
          "name": "featureSectionEyebrow",
          "type": "string"
        },
        {
          "title": "featureSectionTitle",
          "name": "featureSectionTitle",
          "type": "string"
        },
        {
          "title": "projectSectionEyebrow",
          "name": "projectSectionEyebrow",
          "type": "string"
        },
        {
          "title": "projectSectionTitle",
          "name": "projectSectionTitle",
          "type": "string"
        },
        {
          "title": "projectLinkLabel",
          "name": "projectLinkLabel",
          "type": "string"
        },
        {
          "title": "faqSectionEyebrow",
          "name": "faqSectionEyebrow",
          "type": "string"
        },
        {
          "title": "faqSectionTitle",
          "name": "faqSectionTitle",
          "type": "string"
        }
      ]
    }
  ]
}