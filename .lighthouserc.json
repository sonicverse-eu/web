{
	"ci": {
		"collect": {
			"url": [
				"http://127.0.0.1:4321/",
				"http://127.0.0.1:4321/about",
				"http://127.0.0.1:4321/projects",
				"http://127.0.0.1:4321/community",
				"http://127.0.0.1:4321/contact",
				"http://127.0.0.1:4321/blog"
			],
			"numberOfRuns": 3,
			"startServerCommand": "pnpm preview --host 127.0.0.1 --port 4321",
			"startServerReadyPattern": "Local",
			"startServerReadyTimeout": 120000,
			"settings": {
				"chromeFlags": "--no-sandbox"
			}
		},
		"assert": {
			"assertions": {
				"categories:performance": [
					"error",
					{
						"minScore": 0.9
					}
				],
				"categories:accessibility": [
					"error",
					{
						"minScore": 0.95
					}
				],
				"categories:best-practices": [
					"error",
					{
						"minScore": 0.9
					}
				],
				"categories:seo": [
					"error",
					{
						"minScore": 0.9
					}
				]
			}
		},
		"upload": {
			"target": "temporary-public-storage"
		}
	}
}
